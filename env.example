# ══════════════════════════════════════════════════════════════════════════════
# JeiGuard AI v2.0.0 — Variables de entorno
# Copyright (c) 2026 Jeiner Tello Nuñez
#
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a GitHub.
# ══════════════════════════════════════════════════════════════════════════════

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_SASL_USER=
KAFKA_SASL_PASS=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_BOOTSTRAP=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=CHANGE_ME

# ── PostgreSQL (v2.0.0) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jeiguard:jeiguard2026@localhost:5432/jeiguard_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis (v2.0.0) ────────────────────────────────────────────────────────────
REDIS_URL=redis://:jeiguard2026@localhost:6379/0
REDIS_SESSION_TTL_SECONDS=3600

# ── Autenticación JWT (v2.0.0) ────────────────────────────────────────────────
# IMPORTANTE: Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Servicios ─────────────────────────────────────────────────────────────────
PRODUCER_MODE=synthetic
FLOWS_PER_SECOND=1000
SENSOR_ID=sensor-01
DRY_RUN=true

# ── Modelo ────────────────────────────────────────────────────────────────────
MODEL_PATH=models/
INFERENCE_BATCH_SIZE=32
SCALER_PATH=models/scaler.joblib

# ── Alertas ───────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
ALERT_MIN_LEVEL=HIGH

# ── MLflow (v2.0.0) ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=jeiguard-ensemble

# ── OpenTelemetry (v2.0.0) ────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=jeiguard-ai
OTEL_SERVICE_VERSION=2.0.0
OTLP_ENDPOINT=http://jaeger:4317
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
OTEL_DEBUG_CONSOLE=false

# ── Threat Intelligence ────────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=CHANGE_ME
VIRUSTOTAL_API_KEY=CHANGE_ME
NVD_API_KEY=CHANGE_ME

# ── LLM Analyst ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME

# ── Reportes PDF ──────────────────────────────────────────────────────────────
REPORTS_DIR=/tmp/jeiguard_reports

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
